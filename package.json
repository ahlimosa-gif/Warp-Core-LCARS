{
  "name": "warp-core-lcars",
  "version": "0.1.0",
  "description": "Universal LCARS terminal interface wrapper for OS/2 Warp and modern Node.js environments.",
  "main": "test-router.js",
  "bin": {
    "warpcore": "./test-router.js"
  },
  "scripts": {
    "start": "node test-router.js",
    "warpcore": "node test-router.js",
    "smoke": "node scripts/smoke-test.js",
