    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run pack:dry-run"
  },
  "files": [
    "LCARS_FONT.TXT",
    "Node.js",
    "install.cmd",
    "scripts/",
    "test-router.js",
    "warpcore.cmd"
  ],
  "publishConfig": {
